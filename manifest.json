{
    "_version": "1.33.0",
    "sap.app": {
        "id": "Homepage.Homepage",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "1.0.0"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}"
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "images/FavIcon48.png",
            "favIcon": "images/FavIcon48.png",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "rootView": {
            "viewName": "Homepage.Homepage.view.AppView",
            "type": "XML",
            "async": true,
            "id": "AppView"
        },
        "dependencies": {
            "minUI5Version": "1.141.1",
            "libs": {
                "sap.ui.layout": {},
                "sap.ui.core": {},
                "sap.m": {},
                "sap.ui.unified": {},
                "sap.ui.richtexteditor": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "Homepage.Homepage.i18n.i18n"
                }
            },
            "localDataModelContactMe": {
                "type": "sap.ui.model.json.JSONModel",
                "settings": {},
                "preload": false
            },
            "localDataModelLogin": {
                "type": "sap.ui.model.json.JSONModel",
                "settings": {},
                "preload": false
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "viewType": "XML",
                "async": true,
                "viewPath": "Homepage.Homepage.view",
                "controlAggregation": "pages",
                "controlId": "rootContainer",
                "clearControlAggregation": false
            },
            "routes": [
                {
                    "name": "HomeView",
                    "pattern": "",
                    "target": [
                        "HomeView"
                    ]
                },
                {
                    "name": "ListView",
                    "pattern": "ListView",
                    "titleTarget": "",
                    "greedy": false,
                    "target": [
                        "ListView"
                    ]
                },
                {
                    "name": "AboutMeView",
                    "pattern": "AboutMe",
                    "titleTarget": "",
                    "greedy": false,
                    "target": [
                        "AboutMeView"
                    ]
                },
                {
                    "name": "WikiView",
                    "pattern": "Wiki",
                    "titleTarget": "",
                    "greedy": false,
                    "target": [
                        "WikiView"
                    ]
                },
                {
                    "name": "WikiDetailView",
                    "pattern": "Wiki/{Id}",
                    "titleTarget": "",
                    "greedy": false,
                    "target": [
                        "WikiDetailView"
                    ]
                },
                {
                    "name": "WikiOverviewView",
                    "pattern": "WikiOverview",
                    "titleTarget": "",
                    "greedy": false,
                    "target": [
                        "WikiOverviewView"
                    ]
                }
            ],
            "targets": {
                "ListView": {
                    "viewType": "XML",
                    "viewName": "ListView",
                    "viewId": "ViewIdList",
                    "viewLevel": 2
                },
                "AppView": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewName": "AppView",
                    "viewId": "ViewIdApp",
                    "viewLevel": 1
                },
                "AboutMeView": {
                    "viewType": "XML",
                    "viewName": "AboutMeView",
                    "viewLevel": 2,
                    "viewId": "ViewIdAboutMe"
                },
                "WikiView": {
                    "viewType": "XML",
                    "viewName": "WikiView",
                    "viewId": "ViewIdWiki",
                    "viewLevel": 2
                },
                "WikiDetailView": {
                    "viewType": "XML",
                    "viewName": "WikiDetailView",
                    "viewId": "ViewIdWikiDetail",
                    "viewLevel": 3
                },
                "HomeView": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewName": "HomeView",
                    "viewLevel": 1,
                    "viewId": "ViewIdHome"
                },
                "WikiOverviewView": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewName": "WikiOverviewView",
                    "viewId": "ViewIdWikiOverview",
                    "viewLevel": 2
                }
            }
        }
    }
}