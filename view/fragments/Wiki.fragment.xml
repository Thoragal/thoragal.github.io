<core:FragmentDefinition	xmlns="sap.m"
							xmlns:core="sap.ui.core">

	<VBox>
		<Toolbar visible="{adminModeModel>/isAdmin}">
			<ToolbarSpacer/>
			<Button	icon="sap-icon://add"
					tooltip="{i18n>WikiNewEntry}"
					type="Transparent"
					press=".onWikiEntryAdd"/>
		</Toolbar>

		<List	mode="None"
				items="{WikiModel>/Wiki}">
			<CustomListItem>
				<VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
					<HBox width="100%" justifyContent="SpaceBetween" alignItems="Center">
						<Link	text="{WikiModel>title}"
								press="onPressRow"
								class="wikiEntryTitle"/>
						<HBox visible="{adminModeModel>/isAdmin}" alignItems="Center">
							<core:Icon	src="sap-icon://locked"
										class="sapUiTinyMarginEnd wikiPrivateIndicator"
										visible="{= ${WikiModel>is_private} }"/>
							<Button icon="sap-icon://edit" press=".onWikiEntryEdit" type="Transparent"/>
							<Button icon="sap-icon://delete" press=".onWikiEntryDelete" type="Transparent"/>
						</HBox>
					</HBox>
					<VBox items="{ path: 'WikiModel>blocks', factory: '.createWikiBlock', length: 8 }"/>
					<Link	text="{i18n>ShowMore}"
							press="onPressRow"
							visible="{= ${WikiModel>blocks}.length &gt; 8 }"
							class="sapUiTinyMarginTop"/>
				</VBox>
			</CustomListItem>
		</List>
	</VBox>

</core:FragmentDefinition>
