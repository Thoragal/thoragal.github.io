<core:FragmentDefinition	xmlns="sap.m"
							xmlns:core="sap.ui.core">

	<VBox>
		<MessageStrip
			id="idWikiLoadError"
			text="{i18n>WikiLoadError}"
			type="Error"
			showIcon="true"
			showCloseButton="false"
			class="sapUiSmallMargin"
			visible="{WikiModel>/loadError}"/>
		<Toolbar visible="{adminModeModel>/isAdmin}">
			<ToolbarSpacer/>
			<Button	icon="sap-icon://add"
					tooltip="{i18n>WikiNewEntry}"
					type="Transparent"
					press=".onWikiEntryAdd"/>
		</Toolbar>

		<List	mode="None"
				items="{WikiModel>/Wiki}">
			<CustomListItem>
				<VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
					<HBox width="100%" justifyContent="SpaceBetween" alignItems="Center">
						<Link	text="{WikiModel>title}"
								press="onPressRow"
								class="wikiEntryTitle"/>
						<HBox alignItems="Center">
							<core:Icon	src="sap-icon://attachment"
										class="sapUiTinyMarginEnd wikiAttachmentIndicator"
										visible="{= ${WikiModel>files}.length > 0 }"/>
							<core:Icon	src="sap-icon://locked"
										class="sapUiTinyMarginEnd wikiPrivateIndicator"
										visible="{= ${adminModeModel>/isAdmin} &amp;&amp; ${WikiModel>is_private} }"/>
							<HBox visible="{adminModeModel>/isAdmin}" alignItems="Center">
								<Button icon="sap-icon://edit" tooltip="{i18n>AdminBtnEdit}" press=".onWikiEntryEdit" type="Transparent"/>
								<Button icon="sap-icon://delete" tooltip="{i18n>AdminBtnDelete}" press=".onWikiEntryDelete" type="Transparent"/>
							</HBox>
						</HBox>
					</HBox>
					<VBox items="{ path: 'WikiModel>blocks', factory: '.createWikiBlock', length: 8 }"/>
					<Link	text="{i18n>ShowMore}"
							press="onPressRow"
							visible="{= ${WikiModel>blocks}.length &gt; 8 }"
							class="sapUiTinyMarginTop"/>
				</VBox>
			</CustomListItem>
		</List>
	</VBox>

</core:FragmentDefinition>
