<core:FragmentDefinition	xmlns="sap.m" 
							xmlns:core="sap.ui.core" 
							xmlns:l="sap.ui.layout" 
							xmlns:f="sap.ui.layout.form">
	<Dialog id="idLanguage" 
			title="{i18n>LanguageTitle}">
		<content>
	<VBox class="sapUiSmallMargin">
		<Label labelFor="rbg1" text="{i18n>LanguageDefine}" />
		<RadioButtonGroup id="rbg1">
			<RadioButton id="RB1-1" text="{i18n>German}">
				<customData><core:CustomData key="lang" value="de"/></customData>
			</RadioButton>
			<RadioButton id="RB1-2" text="{i18n>English}">
				<customData><core:CustomData key="lang" value="en"/></customData>
			</RadioButton>
			<RadioButton id="RB1-3" text="{i18n>Spanish}">
				<customData><core:CustomData key="lang" value="es"/></customData>
			</RadioButton>
		</RadioButtonGroup>
	</VBox>
		</content>
<!--Buttons-->
		<Toolbar>
			<Button id="idBtnLanguageCancel" press="onPressLanguageDialogCancel" text="{i18n>LanguageCancel}" type="Transparent"/>
			<ToolbarSpacer/>
			<Button id="idBtnLanguageApply" press="onPressLanguageDialogApply" text="{i18n>LanguageApply}" type="Emphasized"/>
		</Toolbar>
	</Dialog>
</core:FragmentDefinition>