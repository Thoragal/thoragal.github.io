<core:FragmentDefinition	xmlns="sap.m" 
							xmlns:mvc="sap.ui.core.mvc"
							xmlns:core="sap.ui.core"
							xmlns:f="sap.ui.layout.form"
							xmlns:uxap="sap.uxap"
							xmlns:l="sap.ui.layout"
							xmlns:html="http://www.w3.org/1999/xhtml">

		<MessageStrip
			id="idWikiOverviewLoadError"
			text="{i18n>WikiLoadError}"
			type="Error"
			showIcon="true"
			showCloseButton="false"
			class="sapUiSmallMargin"
			visible="{WikiModel>/loadError}"/>

		<Table	id="IdObjectTableDataWiki"
				width="auto"
				items="{WikiModel>/Wiki}">

				<headerToolbar>
					<Toolbar visible="{adminModeModel>/isAdmin}">
						<ToolbarSpacer/>
						<Button	icon="sap-icon://add"
								tooltip="{i18n>WikiNewEntry}"
								type="Transparent"
								press=".onWikiEntryAdd"/>
					</Toolbar>
				</headerToolbar>

				<columns>
					<Column id="IdColumnNameType1"
							width="5em"
							demandPopin="true"
							minScreenWidth="Tablet">
						<Text
							id="nameColumnTitle4"
							text="{i18n>WikiOverviewTableId}"/>
					</Column>
					<Column
						id="IdColumnNameValue3"
						demandPopin="true"
						minScreenWidth="Tablet"
						width="8em">
						<Text text="{i18n>WikiOverviewTableDate}"/>
					</Column>
					<Column id="IdColumnNameType2">
						<Text
							id="nameColumnTitle"
							text="{i18n>WikiOverviewTableTitle}"/>
					</Column>
					<Column id="IdColumnWikiOverviewPrivate"
							width="7em"
							hAlign="End">
						<Text text="{i18n>WikiOverviewTableInfo}"/>
					</Column>
					<Column id="IdColumnWikiOverviewActions"
							width="6em"
							hAlign="End"
							visible="{adminModeModel>/isAdmin}">
						<Text text="{i18n>AdminTableColumnActions}"/>
					</Column>
				</columns>

				<items>
					<ColumnListItem
						type="Active"
						press="onPressRow">
						<cells>
							<ObjectIdentifier
								title="{WikiModel>id}"/>
								<Text text = "{ path: 'WikiModel>date', formatter: '.formatter.date' }"/>
								<Text text = "{WikiModel>title}"/>
								<HBox alignItems="Center" justifyContent="End">
									<core:Icon	src="sap-icon://attachment"
												class="wikiAttachmentIndicator"
												visible="{= ${WikiModel>files}.length > 0 }"/>
									<core:Icon	src="sap-icon://locked"
												visible="{= ${adminModeModel>/isAdmin} &amp;&amp; ${WikiModel>is_private} }"
												class="sapUiTinyMarginBegin wikiPrivateIndicator"/>
								</HBox>
								<HBox visible="{adminModeModel>/isAdmin}">
									<Button icon="sap-icon://edit" tooltip="{i18n>AdminBtnEdit}" press=".onWikiEntryEdit" type="Transparent"/>
									<Button icon="sap-icon://delete" tooltip="{i18n>AdminBtnDelete}" press=".onWikiEntryDelete" type="Transparent"/>
								</HBox>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
			
</core:FragmentDefinition>