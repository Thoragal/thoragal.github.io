<core:FragmentDefinition	xmlns="sap.m"
							xmlns:core="sap.ui.core">

	<Toolbar id="idToolbarWikiDetailAdmin" visible="{adminModeModel>/isAdmin}">
		<ToolbarSpacer/>
		<Button	id="idBtnWikiDetailAdd"
				icon="sap-icon://add"
				tooltip="{i18n>WikiNewEntry}"
				type="Transparent"
				press=".onWikiEntryAdd"/>
		<Button id="idBtnWikiDetailEdit" icon="sap-icon://edit" press=".onWikiDetailEntryEdit" type="Transparent"/>
		<Button id="idBtnWikiDetailDelete" icon="sap-icon://delete" press=".onWikiDetailEntryDelete" type="Transparent"/>
	</Toolbar>

	<ObjectHeader	id="idObjectHeader"
					title="{WikiModel>title}">
		<ObjectAttribute	title="{i18n>WikiId}"
							text="{WikiModel>id}"/>
		<ObjectAttribute	title="{i18n>WikiTags}"
							text="{ path: 'WikiModel>tags', formatter: '.formatter.joinTags' }"
							visible="{ path: 'WikiModel>tags', formatter: '.formatter.hasItems' }"/>
		<ObjectAttribute	title="{i18n>WikiCreationDate}"
							text="{ path: 'WikiModel>date', formatter: '.formatter.date' }"/>
		<ObjectAttribute	title="{i18n>WikiEntryPrivateLabel}"
							text="{i18n>WikiPrivateNo}"
							visible="{= ${adminModeModel>/isAdmin} &amp;&amp; !${WikiModel>is_private} }"/>
		<ObjectAttribute	title="{i18n>WikiEntryPrivateLabel}"
							visible="{= ${adminModeModel>/isAdmin} &amp;&amp; !!${WikiModel>is_private} }">
			<customContent>
				<Link	text="{i18n>WikiPrivateYes}"
						endIcon="sap-icon://locked"
						class="wikiPrivateAttribute"/>
			</customContent>
		</ObjectAttribute>
	</ObjectHeader>

	<VBox	id="idBlocksWikiDetail"
			class="sapUiResponsiveContentPadding"/>

</core:FragmentDefinition>
