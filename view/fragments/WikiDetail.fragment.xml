<core:FragmentDefinition	xmlns="sap.m"
							xmlns:core="sap.ui.core">

	<Toolbar id="idToolbarWikiDetailAdmin" visible="{adminModeModel>/isAdmin}">
		<ToolbarSpacer/>
		<Button	id="idBtnWikiDetailAdd"
				icon="sap-icon://add"
				tooltip="{i18n>WikiNewEntry}"
				type="Transparent"
				press=".onWikiEntryAdd"/>
		<Button id="idBtnWikiDetailEdit" icon="sap-icon://edit" tooltip="{i18n>AdminBtnEdit}" press=".onWikiDetailEntryEdit" type="Transparent"/>
		<Button id="idBtnWikiDetailDelete" icon="sap-icon://delete" tooltip="{i18n>AdminBtnDelete}" press=".onWikiDetailEntryDelete" type="Transparent"/>
	</Toolbar>

	<ObjectHeader	id="idObjectHeader"
					title="{WikiModel>title}">
		<ObjectAttribute	title="{i18n>WikiId}"
							text="{WikiModel>id}"/>
		<ObjectAttribute	title="{i18n>WikiTags}"
							text="{ path: 'WikiModel>tags', formatter: '.formatter.joinTags' }"
							visible="{ path: 'WikiModel>tags', formatter: '.formatter.hasItems' }"/>
		<ObjectAttribute	title="{i18n>WikiCreationDate}"
							text="{ path: 'WikiModel>date', formatter: '.formatter.date' }"/>
		<ObjectAttribute	title="{i18n>WikiEntryPrivateLabel}"
							text="{i18n>WikiPrivateNo}"
							visible="{= ${adminModeModel>/isAdmin} &amp;&amp; !${WikiModel>is_private} }"/>
		<ObjectAttribute	title="{i18n>WikiEntryPrivateLabel}"
							visible="{= ${adminModeModel>/isAdmin} &amp;&amp; !!${WikiModel>is_private} }">
			<customContent>
				<Link	text="{i18n>WikiPrivateYes}"
						endIcon="sap-icon://locked"
						class="wikiPrivateAttribute"/>
			</customContent>
		</ObjectAttribute>
	</ObjectHeader>

	<VBox	id="idBlocksWikiDetail"
			class="sapUiResponsiveContentPadding"/>

	<Table	id="idTableWikiDetailAttachments"
			class="sapUiResponsiveContentPadding"
			visible="{= ${WikiModel>files}.length > 0 }"
			items="{WikiModel>files}"
			mode="MultiSelect"
			selectionChange=".onWikiDetailAttachmentSelectionChange"
			noDataText="{i18n>WikiAttachmentsNoData}">
		<headerToolbar>
			<OverflowToolbar>
				<Title text="{i18n>WikiAttachmentsTitle}"/>
				<ToolbarSpacer/>
				<Button	id="idBtnWikiDetailAttachmentsDownload"
						text="{i18n>WikiAttachmentsDownloadSelected}"
						enabled="false"
						press=".onWikiDetailAttachmentsDownload"/>
			</OverflowToolbar>
		</headerToolbar>
		<columns>
			<Column width="2em"/>
			<Column><Text text="{i18n>WikiAttachmentsColFilename}"/></Column>
			<Column><Text text="{i18n>WikiAttachmentsColSize}"/></Column>
			<Column><Text text="{i18n>WikiAttachmentsColDate}"/></Column>
		</columns>
		<items>
			<ColumnListItem>
				<cells>
					<core:Icon src="{ parts: [{path: 'WikiModel>mime_type'}, {path: 'WikiModel>filename'}], formatter: '.formatter.fileTypeIcon' }"/>
					<Link text="{WikiModel>filename}" press=".onWikiDetailFileDownload"/>
					<Text text="{ path: 'WikiModel>size_bytes', formatter: '.formatter.fileSize' }"/>
					<Text text="{ path: 'WikiModel>uploaded_at', formatter: '.formatter.date' }"/>
				</cells>
			</ColumnListItem>
		</items>
	</Table>

</core:FragmentDefinition>
