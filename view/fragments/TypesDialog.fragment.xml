<core:FragmentDefinition xmlns="sap.m"
                          xmlns:core="sap.ui.core">
	<Dialog id="idDialogTypes" title="{i18n>TypesDialogTitle}" contentWidth="30rem" contentHeight="25rem">
		<content>
			<Table id="idTableTypes" items="{TypeManagerModel>/Types}" noDataText="{i18n>TypesNoData}">
				<headerToolbar>
					<Toolbar>
						<Title id="idTitleTypesTable" text="{i18n>TypesDialogTitle}"/>
						<ToolbarSpacer/>
						<Button id="idBtnTypeAdd" icon="sap-icon://add" tooltip="{i18n>TypeBtnAdd}" press=".onPressTypeAdd" type="Transparent"/>
					</Toolbar>
				</headerToolbar>
				<columns>
					<Column id="idColumnTypeLabel">
						<Text text="{i18n>TypeColumnLabel}"/>
					</Column>
					<Column id="idColumnTypeActions" width="6em" hAlign="End">
						<Text text="{i18n>AdminTableColumnActions}"/>
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{TypeManagerModel>label_de}"/>
							<HBox>
								<Button icon="sap-icon://edit" tooltip="{i18n>AdminBtnEdit}" press=".onPressTypeEdit" type="Transparent"/>
								<Button icon="sap-icon://delete" tooltip="{i18n>AdminBtnDelete}" press=".onPressTypeDelete" type="Transparent"/>
							</HBox>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Toolbar>
				<Button id="idBtnTypesClose" press=".onPressTypesClose" text="{i18n>txtBtnContactMeCancel}"/>
				<ToolbarSpacer/>
			</Toolbar>
		</footer>
	</Dialog>
</core:FragmentDefinition>
