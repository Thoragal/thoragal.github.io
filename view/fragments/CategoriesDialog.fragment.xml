<core:FragmentDefinition xmlns="sap.m"
                          xmlns:core="sap.ui.core">
	<Dialog id="idDialogCategories" title="{i18n>CategoriesDialogTitle}" contentWidth="30rem" contentHeight="25rem">
		<content>
			<Table id="idTableCategories" items="{CategoryManagerModel>/Categories}" noDataText="{i18n>CategoriesNoData}">
				<headerToolbar>
					<Toolbar>
						<Title id="idTitleCategoriesTable" text="{i18n>CategoriesDialogTitle}"/>
						<ToolbarSpacer/>
						<Button id="idBtnCategoryAdd" icon="sap-icon://add" tooltip="{i18n>CategoryBtnAdd}" press=".onPressCategoryAdd" type="Transparent"/>
					</Toolbar>
				</headerToolbar>
				<columns>
					<Column id="idColumnCategoryLabel">
						<Text text="{i18n>CategoryColumnLabel}"/>
					</Column>
					<Column id="idColumnCategoryActions" width="6em" hAlign="End">
						<Text text="{i18n>AdminTableColumnActions}"/>
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
							<Text text="{CategoryManagerModel>label_de}"/>
							<HBox>
								<Button icon="sap-icon://edit" tooltip="{i18n>AdminBtnEdit}" press=".onPressCategoryEdit" type="Transparent"/>
								<Button icon="sap-icon://delete" tooltip="{i18n>AdminBtnDelete}" press=".onPressCategoryDelete" type="Transparent"/>
							</HBox>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<footer>
			<Toolbar>
				<Button id="idBtnCategoriesClose" press=".onPressCategoriesClose" text="{i18n>txtBtnContactMeCancel}"/>
				<ToolbarSpacer/>
			</Toolbar>
		</footer>
	</Dialog>
</core:FragmentDefinition>
