<core:FragmentDefinition	xmlns="sap.m"
							xmlns:core="sap.ui.core"
							xmlns:u="sap.ui.unified"
							xmlns:rte="sap.ui.richtexteditor"
							xmlns:plugins="sap.m.plugins"
							xmlns:upload="sap.m.upload"
							xmlns:f="sap.ui.layout.form">
	<Dialog id="idDialogWikiEntry" title="{i18n>WikiEntryDialogTitle}" stretch="true">
		<content>
			<f:SimpleForm id="idFormWikiEntry" editable="true" layout="ResponsiveGridLayout" class="sapUiSmallMarginTop">
				<Label text="{i18n>WikiEntryTitleLabel}"/>
				<Input id="idInputWikiEntryTitle" value="{wikiEntryDraft>/title}" maxLength="500"/>

				<Label text="{i18n>WikiEntryDateLabel}"/>
				<DatePicker value="{wikiEntryDraft>/entry_date}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy"/>

				<Label text="{i18n>WikiEntryTagsLabel}"/>
				<Input value="{wikiEntryDraft>/tagsText}" placeholder="ABAP, UI5"/>

				<Label text="{i18n>WikiEntryPrivateLabel}"/>
				<HBox alignItems="Center">
					<CheckBox selected="{wikiEntryDraft>/is_private}"/>
					<core:Icon	src="sap-icon://locked"
								class="sapUiTinyMarginBegin wikiPrivateIndicator"
								visible="{wikiEntryDraft>/is_private}"/>
				</HBox>
			</f:SimpleForm>

			<Toolbar class="sapUiSmallMarginBegin">
				<Title text="{i18n>WikiEntryBlocksTitle}"/>
				<ToolbarSpacer/>
				<Button icon="sap-icon://add" text="{i18n>WikiBlockAddText}" press=".onWikiAddTextBlock"/>
				<Button icon="sap-icon://add" text="{i18n>WikiBlockAddHtml}" press=".onWikiAddHtmlBlock"/>
				<Button icon="sap-icon://add" text="{i18n>WikiBlockAddCode}" press=".onWikiAddCodeBlock"/>
				<Button icon="sap-icon://add" text="{i18n>WikiBlockAddImage}" press=".onWikiAddImageBlock"/>
			</Toolbar>

			<VBox id="idWikiBlocksEditor" class="sapUiSmallMarginBeginEnd" items="{wikiEntryDraft>/blocks}">
				<Panel class="sapUiTinyMarginBottom">
					<headerToolbar>
						<OverflowToolbar>
							<Label text="{i18n>WikiBlockTypeText}" visible="{= ${wikiEntryDraft>type} === 'text' }"/>
							<Label text="{i18n>WikiBlockTypeCode}" visible="{= ${wikiEntryDraft>type} === 'code' }"/>
							<Label text="{i18n>WikiBlockTypeImage}" visible="{= ${wikiEntryDraft>type} === 'image' }"/>
							<Label text="{i18n>WikiBlockTypeHtml}" visible="{= ${wikiEntryDraft>type} === 'html' }"/>
							<ToolbarSpacer/>
							<Button icon="sap-icon://navigation-up-arrow" tooltip="{i18n>WikiBlockMoveUp}" press=".onWikiBlockMoveUp" type="Transparent"/>
							<Button icon="sap-icon://navigation-down-arrow" tooltip="{i18n>WikiBlockMoveDown}" press=".onWikiBlockMoveDown" type="Transparent"/>
							<Button icon="sap-icon://delete" tooltip="{i18n>WikiBlockDelete}" press=".onWikiBlockDelete" type="Transparent"/>
						</OverflowToolbar>
					</headerToolbar>
					<content>
						<TextArea value="{wikiEntryDraft>content}" rows="6" width="100%" growing="true"
								visible="{= ${wikiEntryDraft>type} === 'text' }"/>

						<VBox visible="{= ${wikiEntryDraft>type} === 'code' }">
							<Input value="{wikiEntryDraft>language}" placeholder="{i18n>WikiBlockLanguagePlaceholder}" class="sapUiTinyMarginBottom"/>
							<TextArea value="{wikiEntryDraft>content}" rows="8" width="100%" growing="true" class="wikiCodeEditor"/>
						</VBox>

						<VBox visible="{= ${wikiEntryDraft>type} === 'image' }">
							<u:FileUploader buttonText="{i18n>WikiImageChoose}" uploadOnChange="false"
									fileType="png,jpg,jpeg,webp,svg,gif" sameFilenameAllowed="true"
									change=".onWikiImageSelected"/>
							<Image src="{ path: 'wikiEntryDraft>image_id', formatter: '.formatter.wikiImageUrl' }"
									visible="{= ${wikiEntryDraft>image_id} !== null &amp;&amp; ${wikiEntryDraft>image_id} !== undefined }"
									class="sapUiTinyMarginTop wikiEditorPreview"/>
							<Input value="{wikiEntryDraft>description}" placeholder="{i18n>WikiBlockDescriptionPlaceholder}" class="sapUiTinyMarginTop"/>
						</VBox>

						<rte:RichTextEditor value="{wikiEntryDraft>content}" height="500px" width="100%"
								showGroupFont="true" showGroupLink="true"
								visible="{= ${wikiEntryDraft>type} === 'html' }"/>
					</content>
				</Panel>
			</VBox>

			<Panel id="idPanelWikiAttachments" headerText="{i18n>WikiAttachmentsTitle}"
					expandable="true" expanded="{= ${wikiEntryDraft>/files}.length > 0 }"
					width="auto"
					class="sapUiSmallMarginTop sapUiSmallMarginBeginEnd">
				<Text text="{i18n>WikiAttachmentsSaveFirstHint}" visible="{= !${wikiEntryDraft>/id} }" class="sapUiSmallMargin"/>

				<Table id="idTableWikiAttachments" visible="{= !!${wikiEntryDraft>/id} }"
						items="{wikiEntryDraft>/files}" noDataText="{i18n>WikiAttachmentsNoData}"
						mode="MultiSelect"
						selectionChange=".onWikiAttachmentsSelectionChange">
					<headerToolbar>
						<OverflowToolbar>
							<ToolbarSpacer/>
							<Button	id="idBtnWikiAttachmentsDownloadSelected"
									text="{i18n>WikiAttachmentsDownloadSelected}"
									enabled="false"
									press=".onWikiAttachmentsDownloadSelected"/>
							<Button	id="idBtnWikiAttachmentsDeleteSelected"
									text="{i18n>WikiAttachmentsDeleteSelected}"
									enabled="false"
									press=".onWikiAttachmentsDeleteSelected"/>
							<upload:ActionsPlaceholder id="idWikiAttachmentsUploadBtn" placeholderFor="UploadButtonPlaceholder"/>
						</OverflowToolbar>
					</headerToolbar>
					<columns>
						<Column width="2em"/>
						<Column><Text text="{i18n>WikiAttachmentsColFilename}"/></Column>
						<Column><Text text="{i18n>WikiAttachmentsColSize}"/></Column>
						<Column width="3em"/>
					</columns>
					<items>
						<ColumnListItem>
							<cells>
								<core:Icon src="{ parts: [{path: 'wikiEntryDraft>mime_type'}, {path: 'wikiEntryDraft>filename'}], formatter: '.formatter.fileTypeIcon' }"
										visible="{= !${wikiEntryDraft>pending} }"/>
								<VBox justifyContent="Center">
									<Text text="{wikiEntryDraft>filename}" visible="{= !${wikiEntryDraft>pending} }"/>
									<!-- Pending (still-uploading) rows are appended client-side in
										 onWikiFileUploadStarted, since they don't exist on the server
										 yet; there's nothing here but a filename/size and live progress
										 until onWikiFileUploadCompleted removes this row again. -->
									<ProgressIndicator visible="{= !!${wikiEntryDraft>pending} }"
											percentValue="{wikiEntryDraft>progress}"
											displayValue="{= ${wikiEntryDraft>filename} + ' – ' + ${wikiEntryDraft>progress} + '%' }"
											width="100%"/>
								</VBox>
								<Text text="{ path: 'wikiEntryDraft>size_bytes', formatter: '.formatter.fileSize' }"
										visible="{= !${wikiEntryDraft>pending} }"/>
								<Button icon="sap-icon://delete" type="Transparent" tooltip="{i18n>WikiAttachmentsDelete}" press=".onWikiFileDelete"
										visible="{= !${wikiEntryDraft>pending} }"/>
							</cells>
						</ColumnListItem>
					</items>
					<dependents>
						<plugins:UploadSetwithTable
								uploadUrl="{wikiEntryDraft>/uploadUrl}"
								fileTypes="pdf,doc,docx,xls,xlsx,ppt,pptx,zip,7z,rar,gz,tar,txt,csv,json,xml,rtf,png,jpg,jpeg,gif,svg,webp"
								maxFileSize="300" multiple="true"
								beforeUploadStarts=".onWikiFileBeforeUploadStarts"
								actions="idWikiAttachmentsUploadBtn">
							<plugins:rowConfiguration>
								<upload:UploadItemConfiguration fileNamePath="filename" mediaTypePath="mime_type"/>
							</plugins:rowConfiguration>
							<plugins:uploader>
								<!-- Default uploader sends the raw file body (useMultipart false);
									 the backend expects a standard multipart/form-data upload
									 (parsed with busboy), so this is switched on explicitly.
									 uploadUrl does not inherit from the plugin's own property
									 once a custom uploader is provided, so it is bound here too.
									 uploadStarted/uploadProgressed/uploadCompleted are attached here
									 (not on the plugin itself): with a custom uploader, the plugin
									 doesn't relay these events up to its own same-named events, and
									 uploadCompleted's parameter shape differs (responseXHR, not a
									 plain status). -->
								<upload:UploaderTableItem useMultipart="true" uploadUrl="{wikiEntryDraft>/uploadUrl}"
										uploadStarted=".onWikiFileUploadStarted"
										uploadProgressed=".onWikiFileUploadProgressed"
										uploadCompleted=".onWikiFileUploadCompleted"/>
							</plugins:uploader>
						</plugins:UploadSetwithTable>
					</dependents>
				</Table>
			</Panel>
		</content>
		<footer>
			<Toolbar>
				<Button text="{i18n>txtBtnContactMeCancel}" press=".onWikiEntryCancel"/>
				<ToolbarSpacer/>
				<Button id="idBtnWikiEntrySave" text="{i18n>ListEntrySave}" type="Emphasized" press=".onWikiEntrySave"/>
			</Toolbar>
		</footer>
	</Dialog>
</core:FragmentDefinition>
